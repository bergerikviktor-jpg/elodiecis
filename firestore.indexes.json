{
  "indexes": [
    {
      "//": "useConversations: where(participants array-contains me) + orderBy(lastMessageAt desc)",
      "collectionGroup": "conversations",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "participants", "arrayConfig": "CONTAINS" },
        { "fieldPath": "lastMessageAt", "order": "DESCENDING" }
      ]
    },
    {
      "//": "useMessages: where(participants array-contains me) + orderBy(createdAt asc).",
      "collectionGroup": "messages",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "participants", "arrayConfig": "CONTAINS" },
        { "fieldPath": "createdAt", "order": "ASCENDING" }
      ]
    },
    {
      "//": "Reverse direction for any pagination usage",
      "collectionGroup": "messages",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "participants", "arrayConfig": "CONTAINS" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "//": "useBoards: where(members array-contains me) + orderBy(updatedAt desc)",
      "collectionGroup": "boards",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "members", "arrayConfig": "CONTAINS" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },
    {
      "//": "useTeams: where(members array-contains me) + orderBy(updatedAt desc)",
      "collectionGroup": "teams",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "members", "arrayConfig": "CONTAINS" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },
    {
      "//": "useMyPendingInvitations: collectionGroup invitations where invitedUid==me + status==pending",
      "collectionGroup": "invitations",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "invitedUid", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "//": "useProjects (active only): where(status=active) + orderBy(updatedAt desc)",
      "collectionGroup": "projects",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },
    {
      "//": "useClients default (active only): where(status=active) + orderBy(createdAt desc)",
      "collectionGroup": "clients",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "//": "useClients sort by company: where(status=active) + orderBy(companyName asc)",
      "collectionGroup": "clients",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "companyName", "order": "ASCENDING" }
      ]
    },
    {
      "//": "useClients sort by recent activity: where(status=active) + orderBy(updatedAt desc)",
      "collectionGroup": "clients",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    }
  ],
  "fieldOverrides": []
}
